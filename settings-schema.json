{
  "enable-cycling": {
    "type": "switch",
    "default": true,
    "description": "Enable repeated command cycling"
  },
  "repeat-timeout": {
    "type": "spinbutton",
    "default": 1500,
    "min": 100,
    "max": 10000,
    "step": 100,
    "units": "ms",
    "description": "Repeat timeout"
  },
  "enable-half-cycling": {
    "type": "switch",
    "default": true,
    "description": "Enable half position cycling"
  },
  "enable-third-cycling": {
    "type": "switch",
    "default": true,
    "description": "Enable third position cycling"
  },
  "enable-fourth-cycling": {
    "type": "switch",
    "default": true,
    "description": "Enable fourth position cycling"
  },
  "enable-corner-cycling": {
    "type": "switch",
    "default": true,
    "description": "Enable corner position cycling"
  },
  "enable-display-cycling": {
    "type": "switch",
    "default": true,
    "description": "Enable display cycling"
  },
  "shortcut-left-half": {
    "type": "keybinding",
    "default": "<Primary><Super>Left",
    "description": "Left Half"
  },
  "shortcut-right-half": {
    "type": "keybinding",
    "default": "<Primary><Super>Right",
    "description": "Right Half"
  },
  "shortcut-top-half": {
