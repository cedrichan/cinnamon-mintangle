{
  "compilerOptions": {
    // GJS (Cinnamon's JS engine) supports modern ECMAScript. Target/lib ES2022;
    // no DOM — this is not a browser environment.
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // esbuild does the actual emit (see scripts/build.mjs). tsc is used only for
    // type-checking via `npm run typecheck`.
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["extension.ts", "src/**/*.ts", "types/**/*.d.ts"]
}
